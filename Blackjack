Console.WriteLine("You have " + money);
Thread.Sleep(textDelay);
//the entire loop
do
{
    wager = 0;  //reset values
    storeCards = true;
    PlayerPoints = 0;
    DealerPoints = 0;
    bust = false;
    tie = false;
    earlyJack = false;
    twoTimes = false; 
    surrender = false;
    do    //wagering
        {
        Console.WriteLine("What's your wager?");
        Thread.Sleep(textDelay);
        wager = Convert.ToInt32(Console.ReadLine());
        Thread.Sleep(textDelay / 5);
        if (wager > money)
        {
            Console.WriteLine("You can't bet more than you have");
            Thread.Sleep(textDelay);
        }
        else if (wager < 1)
        {
            Console.WriteLine("You need to place a wager");
            Thread.Sleep(textDelay);
        }
    } while (wager > money || wager < 1);
    //draw first two cards
    for (int startingGameCards = 0; startingGameCards < 2; startingGameCards++)
    {
        //draw and present card to player
        CardType = BlackJack.Drawing.DrawCard(4);
        CardNumber = BlackJack.Drawing.DrawCard(13);
        Console.WriteLine(BlackJack.Card.CardName(CardType, CardNumber));
        Thread.Sleep(textDelay);
        PlayerPoints = BlackJack.Card.CardValue(CardNumber, PlayerPoints);
        if (PlayerPoints == 21)
        {
            Console.WriteLine("Blackjack!");
            Thread.Sleep(textDelay);
            earlyJack = true;
        }
        //draw card for dealer
        CardType = BlackJack.Drawing.DrawCard(4);
        CardNumber = BlackJack.Drawing.DrawCard(13);
        DealerPoints = BlackJack.Card.CardValue(CardNumber, DealerPoints);
        if (storeCards == true)
        {
            firstCard = BlackJack.Card.CardName(CardType, CardNumber);
            storeCards = false;
        }
    }
    //present cards value
    Console.WriteLine("You have " + PlayerPoints + " points");
    Thread.Sleep(textDelay);
    //present one of the dealers cards
    if (earlyJack == false)
    {
        Console.WriteLine("Dealer has " + BlackJack.Card.CardName(CardType, CardNumber));
    }
    Thread.Sleep(textDelay);
    //surrender or double down
    if (earlyJack == false)
    {
        Console.WriteLine("Do you want to double down or surrender?");
        
        do
        {
            sord = Console.ReadLine();
            Thread.Sleep(textDelay / 5);
            wrongAnswer = false;
            if (sord == "double down") // double down
            {
                if (money - money * 2 < 1)
                {
                    Console.WriteLine("You don't have enough money to double down");
                    Thread.Sleep(textDelay);
                }
                else
                {
                    Console.WriteLine("You chose to double down");
                    Thread.Sleep(textDelay);
                    wager *= 2;
                    twoTimes = true;
                }
            }
            else if (sord == "surrender") //surrender
            {
                surrender = true;
                bust = true;
                if (DealerPoints == 21)
                {
                    Console.WriteLine("Dealer had blackjack and you couldn't surrender");
                }
                else
                {
                    Console.WriteLine("You chose to surrender");
                    Thread.Sleep(textDelay);
                    wager /= 2;
                }
            }
            else if (sord != "no")
            {
                Console.WriteLine("Didn't quite understand you there. Please enter double down, surrender or no");
                Thread.Sleep(textDelay);
                wrongAnswer = true;
            }
        } while (wrongAnswer == true);
    }
    //ask if hit or stand
    if (earlyJack == false && surrender == false && twoTimes == false)
    {
        do
        {
            Console.WriteLine("Hit or stand?");
            Thread.Sleep(textDelay/5);
            do
            {
                stand = false;
                hitOrStand = Console.ReadLine();
                Thread.Sleep(textDelay/5);
                proceed = false;

                if (hitOrStand == "hit") //hit
                {
                    hit = true;
                    proceed = true;

                }
                else if (hitOrStand == "stand") //exit
                {
                    hit = false;
                    proceed = true;
                    stand = true;
                }
                else
                {
                    Console.WriteLine("Didn't quite understand you there. Please enter hit or stand");
                    Thread.Sleep(textDelay);
                }
            } while (proceed == false);
            if (stand == false) //draw a card
            {
                CardType = BlackJack.Drawing.DrawCard(4);
                CardNumber = BlackJack.Drawing.DrawCard(13);
                Console.WriteLine(BlackJack.Card.CardName(CardType, CardNumber));
                Thread.Sleep(textDelay);
                PlayerPoints = BlackJack.Card.CardValue(CardNumber, PlayerPoints);
                Console.WriteLine("You have " + PlayerPoints + " points");
                Thread.Sleep(textDelay);
                if (PlayerPoints > 21) //bust
                {
                    Console.WriteLine("That's a bust...");
                    Thread.Sleep(textDelay);
                    hit = false;
                    bust = true;
                }
                else if (PlayerPoints == 21)    //blackjack
                {
                    Console.WriteLine("Blackjack!");
                    Thread.Sleep(textDelay);
                    hit = false;
                }
            }
        } while (hit == true);
    }
    Console.WriteLine("Dealer has " + BlackJack.Card.CardName(CardType, CardNumber) + " and " + firstCard);
    Thread.Sleep(textDelay);
    if (twoTimes == true)   //double down - draw card
    {
        CardType = BlackJack.Drawing.DrawCard(4);
        CardNumber = BlackJack.Drawing.DrawCard(13);
        Console.WriteLine(BlackJack.Card.CardName(CardType, CardNumber));
        Thread.Sleep(textDelay);
        PlayerPoints = BlackJack.Card.CardValue(CardNumber, PlayerPoints);
        Console.WriteLine("You have " + PlayerPoints + " points");
        Thread.Sleep(textDelay);
        if (PlayerPoints > 21)
        {
            Console.WriteLine("That's a bust...");
            Thread.Sleep(textDelay);
            hit = false;
            bust = true;
        }
        else if (PlayerPoints == 21)
        {
            Console.WriteLine("Blackjack!");
            Thread.Sleep(textDelay);
            hit = false;
        }
    }
    if (DealerPoints <17 && surrender == false)    //dealer draw till 17 or more points
    {
        do
        {
            CardType = BlackJack.Drawing.DrawCard(4);
            CardNumber = BlackJack.Drawing.DrawCard(13);
            DealerPoints = BlackJack.Card.CardValue(CardNumber, DealerPoints);
            Console.WriteLine("Dealer drew a " + BlackJack.Card.CardName(CardType, CardNumber));
            Thread.Sleep(textDelay);
        }   while (DealerPoints < 17);

    }
    if (surrender == false) //win or lose procedure
    {
        Console.WriteLine("Dealer has " + DealerPoints + " points");
        Thread.Sleep(textDelay);
    }
    if (PlayerPoints < DealerPoints && DealerPoints <= 21)
    {
        bust = true;
    }

    if (bust == true)
    {
        Console.WriteLine("You lost...");
        Thread.Sleep(textDelay);
    }
    else if (PlayerPoints == DealerPoints)
    {
        Console.WriteLine("That's a tie");
        Thread.Sleep(textDelay);
        tie = true;
    }
    else
    {
        Console.WriteLine("You won!");
        Thread.Sleep(textDelay);
        wins++;

    }
    if (bust == false && tie == false)
    {
        money += wager;
    }
    else if (bust == true && tie == false)
    {
        money -= wager;
    }
    games++;    //stats from game and new balance
    winPercentage = ((wins / games) * 100);
    winString = decimal.Round(winPercentage, 2, MidpointRounding.AwayFromZero).ToString();
    Console.WriteLine("New balance is " + money);
    Thread.Sleep(textDelay);
    if (money < 1)  //no money or ask to play again
    {
        Console.WriteLine("You're out of money...");
        Thread.Sleep(textDelay);
        playAgain = false;
    }
    else
    {
        Console.WriteLine("Want to play again?");
        Thread.Sleep(textDelay);
        
        do
        {
            wrongAnswer = false;
            playOrNot = Console.ReadLine();

            if (playOrNot == "yes")
            {
                playAgain = true;
            }
            else if (playOrNot != "no")
            {
                wrongAnswer = true;
                Console.WriteLine("Didn't quite understand you there. Please enter yes or no");
                Thread.Sleep(textDelay);
            }
            else
            {
                playAgain = false;
            }
        } while (wrongAnswer == true);
        if (playAgain == true)
        {
            Console.WriteLine("\n");
        }
    }
} while (playAgain == true);
Console.WriteLine("You ended up with " + wins + " wins");   //ending stats
Thread.Sleep(textDelay);
Console.WriteLine("Your win percantage was " + winString + "%");
Thread.Sleep(textDelay);
if (money > 1000)
{
    Console.WriteLine("And your total winnings was " + (money - 1000));
}
else if (money <= 1000)
{
    Console.WriteLine("You lost " + (1000 - money));
}
Thread.Sleep(textDelay);
Console.WriteLine("Bye!");
Console.ReadLine();
