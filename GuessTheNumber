Console.WriteLine("Guess a number between 1 and 1000 and I'll tell you if it's too small or too large.");
double attempts = 0;
double totAttempts = 0;
double numberOfGames = 0;
bool restart = true;
bool attemptAgain = true;
bool wrongAnswer = false;
double avgAttempts;    //variables declared and initialized
do
{
    Random rd = new();
    int randomNum = rd.Next(1, 1000);   
    attemptAgain = true;
    //generate random number and asign to randomNum

    do
    {
        int num = Convert.ToInt32(Console.ReadLine());
        attempts++; //guess number and add attempt to score
        if (num == randomNum)
        {      
            attemptAgain = false;
        Console.WriteLine("That's correct! You used {0} attempts", attempts);  //if correct
    }
        else if (num < randomNum)
        {
            Console.WriteLine("That's too small...");
        }

        else if (num > randomNum)
        {
            Console.WriteLine("That's too large...");
        }
    } while (attemptAgain == true);
    totAttempts += attempts;    //add attempts to total
    attempts = 0;   //reset attempts
    numberOfGames++;    //add to number of games
    avgAttempts = totAttempts / numberOfGames;  //calculate average attempts
    Console.WriteLine("You've played " + numberOfGames + " times and your average attempts is " +
        avgAttempts + "\nWant to try again?"); //message with stats and try again
    do
    {
        string answer = Console.ReadLine();
        wrongAnswer = false;
        if (answer == "yes")
        {
            Console.WriteLine("Start guessing!");
            //next round
        }
        else if (answer == "no")
        {
            Console.WriteLine("Bye!");
            restart = false;    //end program
        }
        else if (answer != "yes" && answer != "no")
        {
            Console.WriteLine("Didn't quite understand you there. Please answer with yes or no");
            wrongAnswer = true;  //ask again
        }
    } while (wrongAnswer == true);
} while (restart == true);
    Console.ReadLine();
